# ---------------------------------------------------------------------------
# Mahalliy ish (Vite dev) — odatda hech narsa yozmasdan ishlaydi (proxy /api).
# Backend port 8000 yoki 8010 bo'lsa, quyidagini moslang:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8010
# ---------------------------------------------------------------------------

# Bitta tashqi API (bulut). Bo'sh qoldirilsa — joriy sahifa origin + fallback lar sinanadi.
# VITE_API_ORIGIN=https://clinicmonitoringapi.ziyrak.org

# Bulut ishlamasa, ketma-ket sinab ko'riladigan qo'shimcha manzillar (vergul bilan).
# Masalan: avval VPS, keyin mahalliy server:
# VITE_API_FALLBACK_ORIGINS=http://192.168.1.10:8010,http://127.0.0.1:8010

# Yoki tartibni to'liq o'zingiz belgilang (yuqoridagi ikkala qator dan ustun):
# VITE_API_ORIGINS=https://clinicmonitoringapi.ziyrak.org,http://127.0.0.1:8010,http://192.168.68.50:8010

# Mindray monitor «Server IP / Port» — faqat UI da ko'rsatish
# VITE_HL7_HOST_PORT=192.168.1.10:6006
